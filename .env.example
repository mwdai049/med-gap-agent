# OpenAI API key (required unless DEMO_MODE=true)
OPENAI_API_KEY=sk-your-key-here

# Models for medical necessity review
OPENAI_MODEL=gpt-5.4-mini
OPENAI_QUERY_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Near-zero temperature for deterministic extraction/classification (0–0.2)
OPENAI_TEMPERATURE_EXTRACTION=0
OPENAI_TEMPERATURE_CLASSIFICATION=0
OPENAI_TEMPERATURE_QUERY=0

# Retrieval settings
POLICY_RAG_TOP_K=4
POLICY_VECTOR_K=5

# Set to true to use pre-authored mock responses (no API key needed)
DEMO_MODE=false
